<Page x:Class="CarRental.Views.CustomerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Zarządzanie Klientami">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="DODAWANIE NOWEGO KLIENTA" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Imię:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="FirstNameTxt" Text="{Binding FirstName, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" Width="300" HorizontalAlignment="Left" Padding="4" Margin="0,0,0,2"/>
            <TextBlock Text="{Binding ElementName=FirstNameTxt, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" Margin="0,0,0,10"/>

            <TextBlock Text="Nazwisko:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="LastNameTxt" Text="{Binding LastName, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" Width="300" HorizontalAlignment="Left" Padding="4" Margin="0,0,0,2"/>
            <TextBlock Text="{Binding ElementName=LastNameTxt, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" Margin="0,0,0,10"/>

            <TextBlock Text="Adres Email:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="EmailTxt" Text="{Binding Email, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" Width="300" HorizontalAlignment="Left" Padding="4" Margin="0,0,0,2"/>
            <TextBlock Text="{Binding ElementName=EmailTxt, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" Margin="0,0,0,10"/>

            <TextBlock Text="Numer telefonu:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="PhoneTxt" Text="{Binding PhoneNumber, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" Width="300" HorizontalAlignment="Left" Padding="4" Margin="0,0,0,2"/>
            <TextBlock Text="{Binding ElementName=PhoneTxt, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" Margin="0,0,0,10"/>

            <TextBlock Text="Numer prawa jazdy:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox x:Name="LicenseTxt" Text="{Binding DrivingLicenseNumber, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" Width="300" HorizontalAlignment="Left" Padding="4" Margin="0,0,0,2"/>
            <TextBlock Text="{Binding ElementName=LicenseTxt, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" Margin="0,0,0,10"/>

            <Button Content="Zapisz Klienta" Click="SaveCustomer_Click" Width="150" HorizontalAlignment="Left" Padding="8" Margin="0,10,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>