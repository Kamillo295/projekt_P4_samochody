<Window x:Class="Car_Rental.Views.CustomerFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Car_Rental.Views"
        mc:Ignorable="d"
        Title="Formularz Klienta" Height="600" Width="400"
        WindowStartupLocation="CenterScreen" Background="#F8F9FA">
    <Grid>
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
            <StackPanel Margin="20">
                <TextBlock Text="DANE KLIENTA" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                <TextBlock Text="Imię:" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                <TextBox x:Name="FirstNameTxt" Text="{Binding FirstName, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="8" FontSize="14" Margin="0,0,0,2" BorderBrush="#BDC3C7"/>
                <TextBlock Text="{Binding ElementName=FirstNameTxt, Path=(Validation.Errors)[0].ErrorContent}" 
                           Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

                <TextBlock Text="Nazwisko:" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                <TextBox x:Name="LastNameTxt" Text="{Binding LastName, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="8" FontSize="14" Margin="0,0,0,2" BorderBrush="#BDC3C7"/>
                <TextBlock Text="{Binding ElementName=LastNameTxt, Path=(Validation.Errors)[0].ErrorContent}" 
                           Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

                <TextBlock Text="Adres Email:" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailTxt" Text="{Binding Email, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="8" FontSize="14" Margin="0,0,0,2" BorderBrush="#BDC3C7"/>
                <TextBlock Text="{Binding ElementName=EmailTxt, Path=(Validation.Errors)[0].ErrorContent}" 
                           Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

                <TextBlock Text="Numer telefonu:" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                <TextBox x:Name="PhoneTxt" Text="{Binding PhoneNumber, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="8" FontSize="14" Margin="0,0,0,2" BorderBrush="#BDC3C7"/>
                <TextBlock Text="{Binding ElementName=PhoneTxt, Path=(Validation.Errors)[0].ErrorContent}" 
                           Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

                <TextBlock Text="Numer prawa jazdy:" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                <TextBox x:Name="LicenseTxt" Text="{Binding DrivingLicenseNumber, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="8" FontSize="14" Margin="0,0,0,2" BorderBrush="#BDC3C7"/>
                <TextBlock Text="{Binding ElementName=LicenseTxt, Path=(Validation.Errors)[0].ErrorContent}" 
                           Foreground="#E74C3C" FontSize="11" Margin="0,0,0,20" MinHeight="16"/>

                <Button Content="💾 Zapisz" Click="SaveButton_Click" Height="45" 
                        Background="#2ECC71" Foreground="White" FontSize="15" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>