<Window x:Class="Car_Rental.Views.CustomerFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Car_Rental.Views"
        mc:Ignorable="d"
        Title="CustomerFormWindow" Height="600" Width="400">
    <Grid>
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,20,0">
            <StackPanel Margin="10">
                <TextBlock Text="DODAWANIE NOWEGO SAMOCHODU" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="Marka samochodu:" FontWeight="SemiBold"/>
                <TextBox x:Name="MakeTxt" Text="{Binding Make, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" Width="250" HorizontalAlignment="Left" Padding="4" Margin="0,2,0,2"/>
                <TextBlock Text="{Binding ElementName=MakeTxt, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" Margin="0,0,0,10"/>

                <TextBlock Text="Model samochodu:" FontWeight="SemiBold"/>
                <TextBox x:Name="ModelTxt" Text="{Binding Model, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" Width="250" HorizontalAlignment="Left" Padding="4" Margin="0,2,0,2"/>
                <TextBlock Text="{Binding ElementName=ModelTxt, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" Margin="0,0,0,10"/>

                <TextBlock Text="Rok produkcji:" FontWeight="SemiBold"/>
                <TextBox x:Name="YearTxt" Text="{Binding Year, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" Width="250" HorizontalAlignment="Left" Padding="4" Margin="0,2,0,2"/>
                <TextBlock Text="{Binding ElementName=YearTxt, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" Margin="0,0,0,10"/>

                <TextBlock Text="Numer rejestracyjny:" FontWeight="SemiBold"/>
                <TextBox x:Name="RegNumTxt" Text="{Binding RegistrationNumber, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" Width="250" HorizontalAlignment="Left" Padding="4" Margin="0,2,0,2"/>
                <TextBlock Text="{Binding ElementName=RegNumTxt, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" Margin="0,0,0,10"/>

                <TextBlock Text="Cena wynajmu (PLN):" FontWeight="SemiBold"/>
                <TextBox x:Name="PriceTxt" Text="{Binding PricePerDay, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" Width="250" HorizontalAlignment="Left" Padding="4" Margin="0,2,0,2"/>
                <TextBlock Text="{Binding ElementName=PriceTxt, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" Margin="0,0,0,10"/>

                <CheckBox x:Name="AvailableChk" Content="Pojazd gotowy do wynajmu" IsChecked="{Binding IsAvailable}" Margin="0,5,0,20"/>

                <Button Content="💾 Zapisz" Click="SaveButton_Click" Height="45" 
        Background="#2ECC71" Foreground="White" FontSize="15" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
