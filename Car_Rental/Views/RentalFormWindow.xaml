<Window x:Class="CarRental.Views.RentalFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nowy Wynajem" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" Background="#F8F9FA">

    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="25">
            <StackPanel>
                <TextBlock Text="REZERWACJA POJAZDU" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Wybierz Klienta:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding ListaKlientow}" 
                      SelectedValue="{Binding CustomerId, UpdateSourceTrigger=PropertyChanged}" 
                      SelectedValuePath="Id" DisplayMemberPath="FullName" 
                      Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Wybierz Samochód (tylko dostępne):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding ListaSamochodow}" 
                      SelectedValue="{Binding CarId, UpdateSourceTrigger=PropertyChanged}" 
                      SelectedValuePath="Id" DisplayMemberPath="FullName" 
                      Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Data rozpoczęcia:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <DatePicker SelectedDate="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Data zakończenia:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <DatePicker SelectedDate="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Całkowity Koszt (PLN):" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,5"/>
                <TextBox Text="{Binding TotalPrice, UpdateSourceTrigger=PropertyChanged}" 
                     IsReadOnly="True" Background="#E8F6F3" FontWeight="Bold" FontSize="16"
                     Padding="8" Margin="0,0,0,25" BorderBrush="#1ABC9C"/>

                <Button Content="💾 Potwierdź Wynajem" Click="SaveButton_Click" Height="45" 
                    Background="#2ECC71" Foreground="White" FontSize="15" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>