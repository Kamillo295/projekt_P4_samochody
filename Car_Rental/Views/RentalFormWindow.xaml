<Window x:Class="CarRental.Views.RentalFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nowy Wynajem" Height="550" Width="400"
        WindowStartupLocation="CenterScreen" Background="#F8F9FA">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="REZERWACJA POJAZDU" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Wybierz Klienta:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CustomerCombo" ItemsSource="{Binding ListaKlientow}" 
                      SelectedValue="{Binding CustomerId, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                      SelectedValuePath="Id" DisplayMemberPath="FullName" 
                      Margin="0,0,0,2" Padding="5"/>
            <TextBlock Text="{Binding ElementName=CustomerCombo, Path=(Validation.Errors)[0].ErrorContent}" 
                       Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

            <TextBlock Text="Wybierz Samochód (tylko dostępne):" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CarCombo" ItemsSource="{Binding ListaSamochodow}" 
                      SelectedValue="{Binding CarId, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                      SelectedValuePath="Id" DisplayMemberPath="FullName" 
                      Margin="0,0,0,2" Padding="5"/>
            <TextBlock Text="{Binding ElementName=CarCombo, Path=(Validation.Errors)[0].ErrorContent}" 
                       Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

            <TextBlock Text="Data rozpoczęcia:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <DatePicker x:Name="StartDP" SelectedDate="{Binding StartDate, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                        Margin="0,0,0,2" Padding="5"/>
            <TextBlock Text="{Binding ElementName=StartDP, Path=(Validation.Errors)[0].ErrorContent}" 
                       Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

            <TextBlock Text="Data zakończenia:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <DatePicker x:Name="EndDP" SelectedDate="{Binding EndDate, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                        Margin="0,0,0,2" Padding="5"/>
            <TextBlock Text="{Binding ElementName=EndDP, Path=(Validation.Errors)[0].ErrorContent}" 
                       Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

            <TextBlock Text="Całkowity Koszt (PLN):" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,5"/>
            <TextBox Text="{Binding TotalPrice, UpdateSourceTrigger=PropertyChanged}" 
                     IsReadOnly="True" Background="#E8F6F3" FontWeight="Bold" FontSize="16"
                     Padding="8" Margin="0,0,0,20" BorderBrush="#1ABC9C"/>

            <Button Content="💾 Potwierdź Wynajem" Click="SaveButton_Click" Height="45" 
                    Background="#2ECC71" Foreground="White" FontSize="15" FontWeight="Bold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>