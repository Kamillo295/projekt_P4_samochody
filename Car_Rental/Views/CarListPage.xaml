<Page x:Class="CarRental.Views.CarListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Lista Samochodów">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="➕ Dodaj Nowy" Click="AddCar_Click" Padding="10,5" Margin="0,0,10,0"/>
            <Button Content="✏️ Edytuj Wybrany" Click="EditCar_Click" Padding="10,5" Margin="0,0,10,0"/>
            <Button Content="🗑️ Usuń Wybrany" Click="DeleteCar_Click" Padding="10,5" Background="#FF6B6B" Foreground="White"/>
        </StackPanel>

        <DataGrid x:Name="CarsDataGrid" Grid.Row="1" ItemsSource="{Binding ListaSamochodow}" 
                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Marka" Binding="{Binding Make}" Width="*"/>
                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="*"/>
                <DataGridTextColumn Header="Rocznik" Binding="{Binding Year}" Width="Auto"/>
                <DataGridTextColumn Header="Rejestracja" Binding="{Binding RegistrationNumber}" Width="*"/>
                <DataGridTextColumn Header="Cena/Dzień" Binding="{Binding PricePerDay}" Width="Auto"/>
                <DataGridCheckBoxColumn Header="Dostępny" Binding="{Binding IsAvailable}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>