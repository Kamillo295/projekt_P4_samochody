<Window x:Class="CarRental.Views.CarFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Formularz Samochodu" Height="600" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F9FA">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="25">
        <StackPanel>

            <TextBlock Text="DANE SAMOCHODU" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,25" HorizontalAlignment="Center"/>

            <TextBlock Text="Marka samochodu:" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
            <TextBox x:Name="MakeTxt" Text="{Binding Make, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="8" FontSize="14" Margin="0,0,0,2" BorderBrush="#BDC3C7"/>
            <TextBlock Text="{Binding ElementName=MakeTxt, Path=(Validation.Errors)[0].ErrorContent}" 
                       Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

            <TextBlock Text="Model samochodu:" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
            <TextBox x:Name="ModelTxt" Text="{Binding Model, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="8" FontSize="14" Margin="0,0,0,2" BorderBrush="#BDC3C7"/>
            <TextBlock Text="{Binding ElementName=ModelTxt, Path=(Validation.Errors)[0].ErrorContent}" 
                       Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

            <TextBlock Text="Rok produkcji:" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
            <TextBox x:Name="YearTxt" Text="{Binding Year, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="8" FontSize="14" Margin="0,0,0,2" BorderBrush="#BDC3C7"/>
            <TextBlock Text="{Binding ElementName=YearTxt, Path=(Validation.Errors)[0].ErrorContent}" 
                       Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

            <TextBlock Text="Numer rejestracyjny:" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
            <TextBox x:Name="RegNumTxt" Text="{Binding RegistrationNumber, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="8" FontSize="14" Margin="0,0,0,2" BorderBrush="#BDC3C7"/>
            <TextBlock Text="{Binding ElementName=RegNumTxt, Path=(Validation.Errors)[0].ErrorContent}" 
                       Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

            <TextBlock Text="Cena wynajmu za dzień (PLN):" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
            <TextBox x:Name="PriceTxt" Text="{Binding PricePerDay, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="8" FontSize="14" Margin="0,0,0,2" BorderBrush="#BDC3C7"/>
            <TextBlock Text="{Binding ElementName=PriceTxt, Path=(Validation.Errors)[0].ErrorContent}" 
                       Foreground="#E74C3C" FontSize="11" Margin="0,0,0,10" MinHeight="16"/>

            <CheckBox x:Name="AvailableChk" Content="Pojazd gotowy do wynajmu (Dostępny)" 
                      IsChecked="{Binding IsAvailable}" 
                      Margin="0,5,0,30" FontSize="14" FontWeight="SemiBold" Foreground="#34495E"/>

            <Button Content="💾 Zapisz" Click="SaveButton_Click" Height="45" 
                    Background="#2ECC71" Foreground="White" FontSize="15" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>
    </ScrollViewer>
</Window>