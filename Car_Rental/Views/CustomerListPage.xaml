<Page x:Class="Car_Rental.Views.CustomerListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Lista Klientów">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="➕ Dodaj Nowy" Click="AddCustomer_Click" Padding="10,5" Margin="0,0,10,0"/>
            <Button Content="✏️ Edytuj Wybrany" Click="EditCustomer_Click" Padding="10,5" Margin="0,0,10,0"/>
            <Button Content="🗑️ Usuń Wybrany" Click="DeleteCustomer_Click" Padding="10,5" Background="#FF6B6B" Foreground="White"/>
        </StackPanel>

        <DataGrid x:Name="CustomerDataGrid" Grid.Row="1" ItemsSource="{Binding ListaKlientow}" 
          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Imię" Binding="{Binding FirstName}" Width="*"/>
                <DataGridTextColumn Header="Nazwisko" Binding="{Binding LastName}" Width="*"/>
                <DataGridTextColumn Header="Numer telefonu" Binding="{Binding PhoneNumber}" Width="Auto"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                <DataGridTextColumn Header="Numer prawa jazdy" Binding="{Binding DrivingLicenseNumber}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Page>
