<Window x:Class="CarRental.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wypożyczalnia Samochodów - Panel Główny" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="MENU" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <Button Content="Samochody" Click="NavCars_Click" Height="40" Margin="0,0,0,10" Background="#34495E" Foreground="White" BorderThickness="0"/>
                <Button Content="Klienci" Click="NavCustomers_Click" Height="40" Margin="0,0,0,10" Background="#34495E" Foreground="White" BorderThickness="0"/>
                <Button Content="Wynajem" Click="NavRentals_Click" Height="40" Margin="0,0,0,10" Background="#34495E" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="#ECF0F1"/>

    </Grid>
</Window>